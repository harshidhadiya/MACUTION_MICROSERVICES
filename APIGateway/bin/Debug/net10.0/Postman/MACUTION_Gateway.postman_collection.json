{
  "info": {
    "name": "MACUTION API Gateway - Full Flow",
    "_postman_id": "macution-gateway-full-001",
    "description": "Single entry point: http://localhost:5000. All responses include ids (id, userId, productId, requestId) for next API calls. Order: 1-User, 2-Admin, 3-Request, 4-Product, 5-Verify. Clear-auction: owner (SELLER/USER) or ADMIN. Request Signup creates user+request via RabbitMQ.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "sellerToken", "value": "", "type": "string" },
    { "key": "userId", "value": "1", "type": "string" },
    { "key": "requestId", "value": "1", "type": "string" },
    { "key": "productId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "1 - User",
      "item": [
        {
          "name": "Create User (USER/SELLER)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var j = pm.response.json();",
                  "    if (j.token) { pm.collectionVariables.set('token', j.token); }",
                  "    if (j.id) { pm.collectionVariables.set('userId', String(j.id)); }",
                  "    if (j.role === 'SELLER' && j.token) pm.collectionVariables.set('sellerToken', j.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"user@test.com\",\n  \"password\": \"P@ssw0rd123\",\n  \"role\": \"USER\",\n  \"phone\": \"1234567890\",\n  \"address\": \"123 Main St\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/user/createUser", "host": ["{{baseUrl}}"], "path": ["api", "user", "createUser"] }
          }
        },
        {
          "name": "Login (User/Seller)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    if (j.token) { pm.collectionVariables.set('token', j.token); pm.collectionVariables.set('sellerToken', j.token); }",
                  "    if (j.Id) pm.collectionVariables.set('userId', String(j.Id)); else if (j.id) pm.collectionVariables.set('userId', String(j.id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@test.com\",\n  \"password\": \"P@ssw0rd123\",\n  \"role\": \"USER\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/user/login", "host": ["{{baseUrl}}"], "path": ["api", "user", "login"] }
          }
        },
        {
          "name": "Get User by Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "user", "{{userId}}"] }
          }
        },
        {
          "name": "Get Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    var d = j.data || j;",
                  "    if (d && d.id) pm.collectionVariables.set('userId', String(d.id));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/getprofile", "host": ["{{baseUrl}}"], "path": ["api", "user", "getprofile"] }
          }
        },
        {
          "name": "User Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/user/dashboard", "host": ["{{baseUrl}}"], "path": ["api", "user", "dashboard"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password\": \"NewP@ssw0rd123\",\n  \"confirmPassword\": \"NewP@ssw0rd123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/user/changepassword", "host": ["{{baseUrl}}"], "path": ["api", "user", "changepassword"] }
          }
        },
        {
          "name": "Change Profile",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/user/changeprofile", "host": ["{{baseUrl}}"], "path": ["api", "user", "changeprofile"] }
          }
        }
      ]
    },
    {
      "name": "2 - Admin (User Service)",
      "item": [
        {
          "name": "Request Signup (ADMIN - creates user + request via RabbitMQ)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    var d = j.data || j;",
                  "    if (d.Id) { pm.collectionVariables.set('userId', String(d.Id)); pm.collectionVariables.set('requestId', String(d.Id)); }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Candidate\",\n  \"email\": \"admin_candidate@test.com\",\n  \"password\": \"P@ssw0rd123\",\n  \"role\": \"ADMIN\",\n  \"phone\": \"1111111111\",\n  \"address\": \"Admin St\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/request/signup", "host": ["{{baseUrl}}"], "path": ["api", "admin", "request", "signup"] }
          }
        },
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    if (j.token) pm.collectionVariables.set('adminToken', j.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@test.com\",\n  \"password\": \"P@ssw0rd123\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/admin/Login", "host": ["{{baseUrl}}"], "path": ["api", "admin", "Login"] }
          }
        },
        {
          "name": "Admin Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/dashboard", "host": ["{{baseUrl}}"], "path": ["api", "admin", "dashboard"] }
          }
        },
        {
          "name": "Get All Verified Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/getallverifiedrequests", "host": ["{{baseUrl}}"], "path": ["api", "admin", "getallverifiedrequests"] }
          }
        },
        {
          "name": "Get Pending Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/pendingrequests", "host": ["{{baseUrl}}"], "path": ["api", "admin", "pendingrequests"] }
          }
        }
      ]
    },
    {
      "name": "3 - Request (ADMIN Service)",
      "item": [
        {
          "name": "Verify Request (makes user verified admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/Request/verify/{{requestId}}", "host": ["{{baseUrl}}"], "path": ["api", "Request", "verify", "{{requestId}}"] }
          }
        },
        {
          "name": "Grant Rights (add-rights to verified user)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/Request/grant-rights/{{requestId}}", "host": ["{{baseUrl}}"], "path": ["api", "Request", "grant-rights", "{{requestId}}"] }
          }
        },
        {
          "name": "Revoke Rights",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/Request/revoke-rights/{{requestId}}", "host": ["{{baseUrl}}"], "path": ["api", "Request", "revoke-rights", "{{requestId}}"] }
          }
        },
        {
          "name": "Revoke Verification",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/Request/revoke-verification/{{requestId}}", "host": ["{{baseUrl}}"], "path": ["api", "Request", "revoke-verification", "{{requestId}}"] }
          }
        },
        {
          "name": "Get Request Details (by user id)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/Request/details/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "Request", "details", "{{userId}}"] }
          }
        },
        {
          "name": "Get User Requests (verified by admin)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/Request/user/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api", "Request", "user", "{{userId}}"] }
          }
        },
        {
          "name": "Get Pending Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/Request/pending", "host": ["{{baseUrl}}"], "path": ["api", "Request", "pending"] }
          }
        },
        {
          "name": "Get Verified Requests",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/Request/verified", "host": ["{{baseUrl}}"], "path": ["api", "Request", "verified"] }
          }
        },
        {
          "name": "Request Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/Request/dashboard", "host": ["{{baseUrl}}"], "path": ["api", "Request", "dashboard"] }
          }
        }
      ]
    },
    {
      "name": "4 - Product",
      "item": [
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    var d = j.data || j;",
                  "    if (d && d.id) pm.collectionVariables.set('productId', String(d.id));",
                  "    if (d && d.userId) pm.collectionVariables.set('userId', String(d.userId));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_name\": \"Laptop\",\n  \"product_description\": \"Gaming laptop\",\n  \"Buy_Date\": \"2024-01-15\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/product/Create", "host": ["{{baseUrl}}"], "path": ["api", "product", "Create"] }
          }
        },
        {
          "name": "Get Product By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var j = pm.response.json();",
                  "    var d = j.data || j;",
                  "    if (d && d.userId) pm.collectionVariables.set('userId', String(d.userId));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/product/GetById/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "product", "GetById", "{{productId}}"] }
          }
        },
        {
          "name": "Get My Products (Seller/User)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/product/get/all/products", "host": ["{{baseUrl}}"], "path": ["api", "product", "get", "all", "products"] }
          }
        },
        {
          "name": "Get All Products (verified listing)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/product/allproducts?isVerified=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "product", "allproducts"],
              "query": [{ "key": "isVerified", "value": "true" }]
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_name\": \"Updated Laptop\",\n  \"product_description\": \"Updated desc\",\n  \"Buy_Date\": \"2024-02-01\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/product/update/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "product", "update", "{{productId}}"] }
          }
        },
        {
          "name": "Schedule Auction (product must be verified)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{sellerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"AuctionStartTime\": \"2025-12-01T10:00:00Z\",\n  \"AuctionEndTime\": \"2025-12-02T10:00:00Z\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/product/{{productId}}/schedule-auction", "host": ["{{baseUrl}}"], "path": ["api", "product", "{{productId}}", "schedule-auction"] }
          }
        },
        {
          "name": "Clear Auction (Owner or ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/product/{{productId}}/clear-auction", "host": ["{{baseUrl}}"], "path": ["api", "product", "{{productId}}", "clear-auction"] }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/product/delete/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "product", "delete", "{{productId}}"] }
          }
        },
        {
          "name": "Product Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{sellerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/product/dashboard", "host": ["{{baseUrl}}"], "path": ["api", "product", "dashboard"] }
          }
        }
      ]
    },
    {
      "name": "5 - Verify",
      "item": [
        {
          "name": "Verify Product (via RabbitMQ)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ProductId\": {{productId}},\n  \"Description\": \"Verified by admin\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/Request/admin/verify", "host": ["{{baseUrl}}"], "path": ["api", "Request", "admin", "verify"] }
          }
        },
        {
          "name": "Verify Product (direct HTTP)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ProductId\": {{productId}},\n  \"SellerId\": {{userId}},\n  \"ProductName\": \"Laptop\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/verify/product", "host": ["{{baseUrl}}"], "path": ["api", "verify", "product"] }
          }
        },
        {
          "name": "Unverify Product (via RabbitMQ)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/Request/admin/unverify/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "Request", "admin", "unverify", "{{productId}}"] }
          }
        },
        {
          "name": "Unverify Product (direct HTTP)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/verify/product/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "verify", "product", "{{productId}}"] }
          }
        },
        {
          "name": "Get Verify Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/verify/status/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "verify", "status", "{{productId}}"] }
          }
        },
        {
          "name": "My Verified Products (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/verify/my-products", "host": ["{{baseUrl}}"], "path": ["api", "verify", "my-products"] }
          }
        },
        {
          "name": "Unverified Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/verify/unverified-products", "host": ["{{baseUrl}}"], "path": ["api", "verify", "unverified-products"] }
          }
        },
        {
          "name": "Verify Dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/verify/dashboard", "host": ["{{baseUrl}}"], "path": ["api", "verify", "dashboard"] }
          }
        }
      ]
    }
  ]
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "harshidHADIYAHOWAREYOUDFSDFSDSDFGS"
  },
  "Microservice": {
    "Admin": "http://localhost:5087",
    "User": "http://localhost:8080",
    "Product": "http://localhost:5088",
    "Verify": "http://localhost:5089"
  },
  "ReverseProxy": {
    "Routes": {
      "userRoute": {
        "ClusterId": "userCluster",
        "Match": { "Path": "/api/user/{**catch-all}" }
      },
      "adminRoute": {
        "ClusterId": "adminCluster",
        "Match": { "Path": "/api/admin/{**catch-all}" }
      },
      "requestRoute": {
        "ClusterId": "requestCluster",
        "Match": { "Path": "/api/Request/{**catch-all}" }
      },
      "productRoute": {
        "ClusterId": "productCluster",
        "Match": { "Path": "/api/product/{**catch-all}" }
      },
      "verifyRoute": {
        "ClusterId": "verifyCluster",
        "Match": { "Path": "/api/verify/{**catch-all}" }
      }
    },
    "Clusters": {
      "userCluster": {
        "Destinations": { "d1": { "Address": "http://localhost:8080/" } }
      },
      "adminCluster": {
        "Destinations": { "d1": { "Address": "http://localhost:8080/" } }
      },
      "requestCluster": {
        "Destinations": { "d1": { "Address": "http://localhost:5087/" } }
      },
      "productCluster": {
        "Destinations": { "d1": { "Address": "http://localhost:5088/" } }
      },
      "verifyCluster": {
        "Destinations": { "d1": { "Address": "http://localhost:5089/" } }
      }
    }
  }
}
